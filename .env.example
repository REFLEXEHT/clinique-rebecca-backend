# Base de données PostgreSQL (Render fournit automatiquement DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/clinique_rebecca

# JWT — générer avec: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGEZ-CETTE-CLE-FORTE-EN-PRODUCTION

# Mot de passe admin initial — changer après premier login
ADMIN_DEFAULT_PASSWORD=MotDePasseForte2026!

# Environnement
ENVIRONMENT=production

# CORS — URL du frontend Vercel (sans slash final)
CORS_ORIGINS=https://clinique-rebecca.vercel.app,https://cliniquerebecca.ht

# Email SMTP (optionnel)
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=votre-app-password

# API Anthropic pour le chat IA (optionnel)
ANTHROPIC_API_KEY=sk-ant-...
