# Backend Environment Variables — Clinique de la Rebecca
# Copiez ce fichier en .env et complétez les valeurs

# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://rebecca:rebecca2026@localhost:5432/clinique_rebecca
# Pour Render.com: utilisez l'URL fournie automatiquement

# === SÉCURITÉ JWT ===
SECRET_KEY=changez-cette-cle-en-production-minimum-32-caracteres-aleatoires
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === IA (Claude Anthropic) ===
ANTHROPIC_API_KEY=sk-ant-...  # Depuis console.anthropic.com

# === EMAIL SMTP (Gmail recommandé) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votremail@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-application  # Pas votre mot de passe Gmail normal

# === EMAILS INTERNES CLINIQUE ===
ADMIN_EMAIL=admin@cliniquerebecca.ht
CAISSE_EMAIL=caisse@cliniquerebecca.ht
MEDECIN_EMAIL=medecin@cliniquerebecca.ht

# === WHATSAPP / TÉLÉPHONE ===
WHATSAPP_PHONE=50938880000  # Sans + ni espaces
CLINIQUE_TELEPHONE=+509 3888-0000

# === CORS (Frontend URLs autorisées) ===
CORS_ORIGINS=https://clinique-rebecca-frontend.vercel.app,http://localhost:3000

# === COMPTES PAR DÉFAUT (créés automatiquement au démarrage) ===
# admin@cliniquerebecca.ht / rebecca2026
